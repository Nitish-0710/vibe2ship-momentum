# =============================================================
# Momentum — Environment Variables
# =============================================================
# Copy this file to .env in the backend/ directory and fill in
# your actual values. Never commit .env to version control.
# =============================================================

# ─── Backend Server ─────────────────────────────────────────
PORT=5000

# ─── Firebase Admin SDK (Backend) ───────────────────────────
# Your Firebase project ID (required for Admin SDK)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Option A — Application Default Credentials (recommended for Cloud Run)
# Run: gcloud auth application-default login
# GOOGLE_APPLICATION_CREDENTIALS is set automatically

# Option B — Service Account Key File
# Download from Firebase Console > Project Settings > Service Accounts
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ─── Gemini API ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# =============================================================
# Frontend Environment Variables (prefix: VITE_)
# Place these in frontend/.env.local
# =============================================================

# ─── Firebase Client SDK (Frontend) ─────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# ─── API URL ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
